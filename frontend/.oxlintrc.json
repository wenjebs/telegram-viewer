{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-debugger": "error",
    "no-console": "warn",
    "react/react-in-jsx-scope": "off"
  },
  "settings": {
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": "19",
      "componentWrapperFunctions": []
    }
  },
  "ignorePatterns": ["dist", "node_modules"]
}
